---
// Hero.astro — the animated "quiet field" landing hero.
// A canvas particle field reacts to the cursor; an aurora glow follows it;
// a monospace eyebrow types itself out. All motion is skipped under
// prefers-reduced-motion (see the media query and the script guard).
---
<section class="hero" aria-label="Sakar Labs — notes from the lab">
  <div class="aurora" aria-hidden="true"></div>
  <canvas class="field" aria-hidden="true"></canvas>
  <div class="glow" aria-hidden="true"></div>

  <div class="hero-inner">
    <p class="eyebrow" aria-hidden="true"><span class="typed" data-text="sakar-labs ~ notes --weekly"></span><span class="caret"></span></p>
    <h1 class="headline"><span class="w">Notes</span> <span class="w">from&nbsp;the&nbsp;lab.</span></h1>
    <p class="lede">Weekly, considered writing on
      <span class="rot"><b>software</b><b>AI</b><b>systems</b><b>craft</b></span>
      from the Sakar Labs team.</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: #ffffff;
    min-height: clamp(360px, 62vh, 560px);
    display: flex;
    align-items: center;
  }

  /* Aurora colour layer — faint drifting blobs + cursor-follow tint */
  .aurora { position: absolute; inset: 0; --mx: 50%; --my: 45%; pointer-events: none; }
  .aurora::before, .aurora::after {
    content: ""; position: absolute; width: min(46vw, 460px); height: min(46vw, 460px);
    border-radius: 50%; filter: blur(80px); opacity: .10;
  }
  .aurora::before { background: #2563eb; top: -16%; left: -8%; animation: drift1 13s ease-in-out infinite alternate; }
  .aurora::after  { background: #7c3aed; bottom: -20%; right: -6%; animation: drift2 16s ease-in-out infinite alternate; }
  @keyframes drift1 { to { transform: translate(140px, 80px) scale(1.2); } }
  @keyframes drift2 { to { transform: translate(-120px, -70px) scale(1.15); } }

  .field { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }

  .glow {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(240px 240px at var(--mx, 50%) var(--my, 45%),
      rgba(37, 99, 235, .12), rgba(124, 58, 237, .07) 45%, transparent 70%);
  }

  .hero-inner {
    position: relative; z-index: 3;
    width: 100%; max-width: 1000px; margin-inline: auto; padding: 2.5rem 1.5rem;
  }

  .eyebrow { font-family: var(--font-mono); font-size: .85rem; color: var(--text-muted); margin: 0 0 1.1rem; }
  .caret {
    display: inline-block; width: 2px; height: 1em; background: var(--accent);
    margin-left: 1px; vertical-align: -2px; animation: blink 1s step-end infinite;
  }

  .headline { margin: 0; font-size: clamp(2.4rem, 6vw, 3.6rem); line-height: 1.02; letter-spacing: -.03em; color: #151515; }
  .headline .w { display: inline-block; opacity: 0; transform: translateY(16px); animation: rise .8s cubic-bezier(.2, .75, .2, 1) forwards; }
  .headline .w:nth-child(1) { animation-delay: .5s; }
  .headline .w:nth-child(2) { animation-delay: .66s; }

  .lede { margin: 1.2rem 0 0; color: var(--text-muted); font-size: clamp(1rem, 2.2vw, 1.2rem); max-width: 60ch; opacity: 0; animation: rise .8s ease forwards 1.05s; }
  .rot { display: inline-grid; }
  .rot > b { grid-area: 1 / 1; color: var(--accent); font-weight: 700; opacity: 0; animation: cycle 8.4s infinite; }
  .rot > b:nth-child(1) { animation-delay: 1.4s; }
  .rot > b:nth-child(2) { animation-delay: 3.5s; }
  .rot > b:nth-child(3) { animation-delay: 5.6s; }
  .rot > b:nth-child(4) { animation-delay: 7.7s; }

  @keyframes rise { to { opacity: 1; transform: none; } }
  @keyframes blink { 50% { opacity: 0; } }
  @keyframes cycle {
    0% { opacity: 0; transform: translateY(9px); }
    3% { opacity: 1; transform: none; }
    22% { opacity: 1; }
    25% { opacity: 0; transform: translateY(-9px); }
    100% { opacity: 0; }
  }

  /* Respect reduced-motion: freeze everything to a clean static state */
  @media (prefers-reduced-motion: reduce) {
    .aurora::before, .aurora::after,
    .headline .w, .lede, .caret, .rot > b { animation: none !important; }
    .headline .w, .lede { opacity: 1; transform: none; }
    .rot > b:nth-child(1) { opacity: 1; }
    .rot > b:nth-child(n+2) { opacity: 0; }
  }
</style>

<script>
  // Skip all JS-driven motion under reduced-motion; just fill in the eyebrow text.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const hero = document.querySelector<HTMLElement>('.hero');

  if (hero) {
    const typed = hero.querySelector<HTMLElement>('.typed');
    const full = typed?.dataset.text ?? '';

    if (reduce) {
      if (typed) typed.textContent = full;
    } else {
      // Typing eyebrow
      if (typed) {
        let i = 0;
        const step = () => {
          typed.textContent = full.slice(0, i);
          if (i++ <= full.length) setTimeout(step, 55);
        };
        step();
      }

      // Canvas particle field
      const canvas = hero.querySelector<HTMLCanvasElement>('.field');
      const glow = hero.querySelector<HTMLElement>('.glow');
      const aurora = hero.querySelector<HTMLElement>('.aurora');
      const ctx = canvas?.getContext('2d');

      if (canvas && ctx) {
        const dpr = Math.min(window.devicePixelRatio || 1, 2);
        let W = 0, H = 0;
        let pts: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
        const mouse = { x: -999, y: -999, on: false };

        const size = () => {
          const r = hero.getBoundingClientRect();
          W = r.width; H = r.height;
          canvas.width = W * dpr; canvas.height = H * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          const n = Math.round((W * H) / 9000); // calm density
          pts = [];
          for (let i = 0; i < n; i++) {
            pts.push({
              x: Math.random() * W, y: Math.random() * H,
              vx: (Math.random() - .5) * .18, vy: (Math.random() - .5) * .18,
              r: 1 + Math.random() * 1.4,
            });
          }
        };

        const frame = () => {
          ctx.clearRect(0, 0, W, H);
          for (const p of pts) {
            p.x += p.vx; p.y += p.vy;
            if (p.x < -10) p.x = W + 10;
            if (p.x > W + 10) p.x = -10;
            if (p.y < -10) p.y = H + 10;
            if (p.y > H + 10) p.y = -10;

            const d = mouse.on ? Math.hypot(p.x - mouse.x, p.y - mouse.y) : 999;
            const near = d < 140;
            const t = near ? 1 - d / 140 : 0;

            if (near) {
              ctx.strokeStyle = `rgba(37,99,235,${(t * 0.5).toFixed(3)})`;
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(p.x, p.y);
              ctx.lineTo(mouse.x, mouse.y);
              ctx.stroke();
            }

            const cr = Math.round(198 + (37 - 198) * t);
            const cg = Math.round(204 + (99 - 204) * t);
            const cb = Math.round(216 + (235 - 216) * t);
            ctx.fillStyle = `rgba(${cr},${cg},${cb},${(0.55 + t * 0.4).toFixed(2)})`;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r + t * 1.2, 0, 6.2832);
            ctx.fill();
          }
          requestAnimationFrame(frame);
        };

        hero.addEventListener('pointermove', (e) => {
          const r = hero.getBoundingClientRect();
          mouse.x = e.clientX - r.left;
          mouse.y = e.clientY - r.top;
          mouse.on = true;
          glow?.style.setProperty('--mx', mouse.x + 'px');
          glow?.style.setProperty('--my', mouse.y + 'px');
          aurora?.style.setProperty('--mx', mouse.x + 'px');
          aurora?.style.setProperty('--my', mouse.y + 'px');
        });
        hero.addEventListener('pointerleave', () => {
          mouse.on = false; mouse.x = -999; mouse.y = -999;
        });

        window.addEventListener('resize', size);
        size();
        requestAnimationFrame(frame);
      }
    }
  }
</script>
